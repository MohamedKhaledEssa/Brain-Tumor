# Copy to .env and adjust as needed.
APP_NAME="Brain Tumor Detection API"
APP_VERSION=0.1.0
ENVIRONMENT=development

HOST=0.0.0.0
PORT=8000

# Path to trained weights; falls back to demo mode if missing.
MODEL_PATH=./models/brain_tumor.pth
MODEL_ARCH=resnet18
DEVICE=auto

MAX_UPLOAD_BYTES=10485760
MAX_BATCH_SIZE=16

# Comma-separated. Use "*" only in development.
CORS_ORIGINS=*

# When true, builds the backbone with ImageNet-pretrained weights.
USE_PRETRAINED_BACKBONE=false
